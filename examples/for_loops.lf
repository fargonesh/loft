// examples/for_loops.lf
// Demonstration of for loops and nesting

fn main() {
    let numbers = [1, 2, 3, 4, 5];
    
    term.println("Iterating over numbers:");
    for n in numbers {
        term.println(n);
    }

    let nested = [[1, 2], [3, 4], [5, 6]];
    term.println("Nested loops:");
    for pair in nested {
        for n in pair {
            term.println(n);
        }
    }

    // Testing the field access in loop body (parser fix)
    def Person {
        name: String,
        age: Number
    }

    let people = [
        Person { name: "Alice", age: 30 },
        Person { name: "Bob", age: 25 }
    ];

    term.println("Iterating over people (testing field access):");
    for p in people {
        term.println(p.name);
        term.println(p.age);
    }
}
